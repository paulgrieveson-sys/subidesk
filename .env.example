# Xero OAuth2
XERO_CLIENT_ID=your_xero_client_id
XERO_CLIENT_SECRET=your_xero_client_secret
XERO_REDIRECT_URI=https://your-vercel-url.vercel.app/api/callback

# Gmail OAuth2
GMAIL_CLIENT_ID=your_gmail_client_id
GMAIL_CLIENT_SECRET=your_gmail_client_secret
GMAIL_REDIRECT_URI=https://your-vercel-url.vercel.app/api/callback

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# GoHighLevel — webhook URL from a GHL workflow trigger
GHL_WEBHOOK_URL=your_ghl_workflow_webhook_url

# Token storage (JSON strings — populated by completing each OAuth flow)
# Copy the value logged to the console after visiting /api/auth?provider=xero
XERO_TOKENS=
# Copy the value logged to the console after visiting /api/auth?provider=gmail
GMAIL_TOKENS=

# App
NODE_ENV=development
